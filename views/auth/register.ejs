    <section class="h-dvh flex items-center justify-center p-4">
        <div class="max-w-sm w-full p-4 border border-neutral-800 bg-neutral-900 rounded">
            <h1 class="text-2xl font-semibold text-white text-center py-2">Join To WonderInk</h1>
            <form action="/api/v23/register" class="flex flex-col gap-3 my-4" autocomplete="off" method="post" onsubmit="return registerValidateForm()">
                <div class="w-full h-10 rounded bg-neutral-700 border border-neutral-700 overflow-hidden">
                    <input type="text" name="username" id="username" placeholder="Enter your user name" class="w-full h-full border-none outline-none px-2 bg-transparent text-base text-white placeholder:text-sm"  required>
                </div>
                <div class="w-full h-10 rounded bg-neutral-700 border border-neutral-700 overflow-hidden">
                    <input type="text" name="fullName" id="fullname" placeholder="Enter your full name" class="w-full h-full border-none outline-none px-2 bg-transparent text-base text-white placeholder:text-sm" required>
                </div>
                <div class="w-full h-10 rounded bg-neutral-700 border border-neutral-700 overflow-hidden">
                    <input type="email" name="email" id="email" placeholder="Enter your email" class="w-full h-full border-none outline-none px-2 bg-transparent text-base text-white placeholder:text-sm" required>
                </div>
                <div class="w-full h-10 rounded bg-neutral-700 border border-neutral-700 overflow-hidden flex items-center justify-center">
                    <input type="password" name="password" id="password" placeholder="Enter your password" class="w-full h-full border-none outline-none px-2 bg-transparent text-base text-white placeholder:text-sm" required>
                    <span class="h-full w-10 flex items-center justify-center cursor-pointer" id="input-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 0 1 0-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                          </svg>
                    </span>
                </div>
                <div>
                    <button type="submit" class="w-full h-10 rounded border-none font-medium tracking-wider text-white  bg-indigo-600 transition-colors duration-200 ease-in-out hover:bg-indigo-500">Register</button>
                </div>
            </form>
            <p>Already have an account?  <a href="/auth/login" class="ms-1 hover:underline">Login now</a></p>
        </div>
    </section>