<section class="py-5 hero-banner-section position-relative mb-5">
  <div class="d-flex align-items-center justify-content-center pt-5">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="index.html" class="display-8 text-white fw-bold text-decoration-none text-white">Home</a></li>
        <li class="breadcrumb-item active" aria-current="page">
          <span class="display-8 text-white fw-bold text-decoration-none text-white">Contact us</span>
        </li>
      </ol>
    </nav>
  </div>
  <div id="particles-js" class="position-absolute top-0"></div>
</section>
<section class="mb-5">
  <div class="container px-0">
    <div class="row">
      <div class="col-md-6 col-12 mx-auto">
        <h1 class="text-white fw-semibold text-center mb-3">Contact us</h1>
        <% if (error_msg.length> 0) { %>
          <div class="custom-alert-error rounded my-2" role="alert">
            <%= error_msg %>
          </div>
          <% } %>
          <% if (success_msg.length> 0) { %>
          <div class="custom-alert-success rounded my-2" role="alert">
            <%= success_msg %>
          </div>
          <% } %>
        <form method="post" action="/api/v1/contact">
          <div class="form-group mb-3">
            <label class="form-label" for="name">Name</label>
            <input type="text" class="form-control" id="name" name="name" placeholder="Your Name" required>
          </div>
          <div class="form-group mb-3">
            <label class="form-label" for="email">Email address</label>
            <input type="email" class="form-control" id="email" name="email" placeholder="Your Email" required>
          </div>
          <div class="form-group mb-3">
            <label class="form-label" for="message">Message</label>
            <textarea class="form-control" id="message" rows="4" name="message" placeholder="Your Message" required></textarea>
          </div>
          <button type="submit" class="btn btn-primary w-100">Send Message</button>
        </form>
      </div>
    </div>
  </div>
</section>