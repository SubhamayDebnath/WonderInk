    <section class="py-5">
        <div class="flex items-center justify-between">
            <h1 class="text-2xl font-bold text-white">Post List</h1>
            <a href="/admin/dashboard/add/post" class="px-2 py-1 rounded text-white bg-blue-600">Add Post</a>
        </div>
        <% if(posts != '') {%>

        <div class="overflow-hidden py-5">
            <div class="overflow-x-scroll">
                <table class="w-[1200px]">
                    <thead class="bg-neutral-800">
                        <tr>
                            <td class="border border-neutral-700 p-2 text-center">No</td>
                            <td class="border border-neutral-700 p-2 text-center">Image</td>
                            <td class="border border-neutral-700 p-2 text-center">Title</td>
                            <td class="border border-neutral-700 p-2 text-center">Category</td>
                            <td class="border border-neutral-700 p-2 text-center">Author</td>
                            <td class="border border-neutral-700 p-2 text-center">Publish Date</td>
                            <td class="border border-neutral-700 p-2 text-center">Status</td>
                            <td class="border border-neutral-700 p-2 text-center">Action</td>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="transition-colors duration-200 ease-in-out hover:bg-blue-500/10">
                            <td class="border border-neutral-700 p-2 text-center">1</td>
                            <td class="border border-neutral-700 p-2 text-center">
                                <div class="h-16 aspect-video overflow-hidden rounded mx-auto">
                                    <img src="../../hero.jpeg" alt="Post image" class="w-full h-full object-cover">
                                </div>
                            </td>
                            <td class="border border-neutral-700 p-2 text-center">
                                <h1 class="line-clamp-2">Authentication and Authorization in Node.js</h1>
                            </td>
                            <td class="border border-neutral-700 p-2 text-center">Technology</td>
                            <td class="border border-neutral-700 p-2 text-center">Admin</td>
                            <td class="border border-neutral-700 p-2 text-center">Aug 16 2069</td>
                            <td class="border border-neutral-700 p-2 text-center">Publish</td>
                            <td class="border border-neutral-700 p-2 text-center">
                                <form action="" class="inline-block">
                                    <select name="status" id="status" class="border border-neutral-700 bg-neutral-800 p-0.5 overflow-hidden rounded mx-1">
                                        <option value="">Publish</option>
                                        <option value="">Draft</option>
                                    </select>
                                </form>
                                <a href="" class="px-2 py-1 rounded text-white bg-blue-600">Edit</a>
                                <a href="" class="px-2 py-1 rounded text-white bg-red-600">Delete</a>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>  
        </div>
        <% }else{ %>
            <div class="flex items-center justify-center h-60"> 
                <p class="text-white text-lg ">No Post Found!</p>
            </div>
        <% } %>
    </section>