    <section class="py-5">
        <% if(users != '') {%>
        <h1 class="text-2xl font-bold text-white">Users List</h1>
        <div class="overflow-hidden py-5">
            <div class="overflow-x-scroll">
                <table class="w-[1200px]">
                    <thead class="bg-neutral-800">
                        <tr>
                            <td class="border border-neutral-700 p-2 text-center">No</td>
                            <td class="border border-neutral-700 p-2 text-center">Image</td>
                            <td class="border border-neutral-700 p-2 text-center">Username</td>
                            <td class="border border-neutral-700 p-2 text-center">Full Name</td>
                            <td class="border border-neutral-700 p-2 text-center">Email</td>
                            <td class="border border-neutral-700 p-2 text-center">Role</td>
                            <td class="border border-neutral-700 p-2 text-center">Status</td>
                            <td class="border border-neutral-700 p-2 text-center">Action</td>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach((data,index) => { %>
                            <tr class="transition-colors duration-200 ease-in-out hover:bg-blue-500/10">
                                <td class="border border-neutral-700 p-2 text-center"><%- index+1 %></td>
                                <td class="border border-neutral-700 p-2 text-center">
                                    <div class="h-10 w-10 rounded-full overflow-hidden mx-auto">
                                        <img src="<%-data.avatar.secure_url  %>" alt="Profile Image">
                                    </div>
                                </td>
                                <td class="border border-neutral-700 p-2 text-center capitalize"><%- data.username %></td>
                                <td class="border border-neutral-700 p-2 text-center capitalize"><%- data.fullName %></td>
                                <td class="border border-neutral-700 p-2 text-center"><%- data.email  %></td>
                                <td class="border border-neutral-700 p-2 text-center capitalize"><%- data.role  %></td>
                                <td class="border border-neutral-700 p-2 text-center"><%-data.status  %></td>
                                <td class="border border-neutral-700 p-2 text-center">
                                    <% if(currentUser.role === 'SUPERUSER' ) {%> 
                                        <form action="" class="inline-block">
                                            <select name="role" id="role" class="border border-neutral-700 bg-neutral-800 p-0.5 overflow-hidden rounded">
                                                <option value="SUPERUSER" <%= data.role === 'SUPERUSER' ? 'selected' : '' %> >Super Admin</option>
                                                <option value="ADMIN" <%= data.role === 'ADMIN' ? 'selected' : '' %> >Admin</option>
                                                <option value="USER" <%= data.role === 'USER' ? 'selected' : '' %> >User</option>
                                            </select>
                                        </form>
                                    <% } %>                              
                                    <form action="" class="inline-block">
                                        <select name="status" id="status" class="border border-neutral-700 bg-neutral-800 p-0.5 overflow-hidden rounded mx-1">
                                            <option value="ACTIVE" <%= data.status === 'ACTIVE' ? 'selected' : '' %> >Active</option>
                                            <option value="INACTIVE" <%= data.status === 'INACTIVE' ? 'selected' : '' %> >Inactive</option>
                                        </select>
                                    </form>
                                    <% if(currentUser.role === 'SUPERUSER' ) {%> 
                                        <a href="" class="px-2 py-1 rounded text-white bg-red-600">Delete</a>
                                    <% } %>
                                    
                                </td>
                            </tr>
                       <% }); %>
                    </tbody>
                </table>
            </div>  
        </div>
        <% }else{ %>
            <div class="flex items-center justify-center h-60"> 
                <p class="text-white text-lg ">No user Found!</p>
            </div>
        <% } %>
    </section>