    <section class="py-5 flex justify-center">
        <div class="max-w-sm w-full p-4 border border-neutral-800 bg-neutral-900 rounded">
            <h1 class="text-2xl font-semibold text-white text-center py-2">Add Category</h1>
            <form action="/admin/api/v23/add/category" method="post" class="flex flex-col gap-3 my-4" onsubmit="return validateForm()">
                <div class="w-full h-10 rounded bg-neutral-700 border border-neutral-700 overflow-hidden">
                    <input type="text" name="name" id="categoryname" placeholder="Enter your category name" class="w-full h-full border-none outline-none px-2 bg-transparent text-base text-white placeholder:text-sm" required >
                </div>
                <div>
                    <button type="submit" class="w-full h-10 rounded border-none font-medium tracking-wider text-white  bg-indigo-600 transition-colors duration-200 ease-in-out hover:bg-indigo-500">Add category</button>
                </div>
            </form>
        </div>
    </section>
    <script>
        function containsOnlyLetters(input) {
            const regex = /^[A-Za-z]+$/;  
            return regex.test(input);
        }
        
        function validateForm() {
            const categoryNameInput = document.getElementById('categoryname').value;
            if (!containsOnlyLetters(categoryNameInput)) {
                alert('Please enter a category name that contains only letters.');
                return false; 
            }
            return true;
        }
        </script>