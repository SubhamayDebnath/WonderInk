    <section class="py-5">
        <% if(categories !=""){ %>
        
        <div class="flex items-center gap-3 flex-wrap py-5" >
            <span  class="text-[15px] font-semibold px-2 py-1 rounded bg-white text-black duration-200 transition-colors ease-in-out capitalize tracking-wide">
                Categories
            </span>
            <% categories.forEach((data)=>{ %>
            <a href="/category/<%- data.name%>" class="text-[15px] font-medium px-2 py-1 rounded border border-neutral-700 hover:bg-neutral-700 duration-200 transition-colors ease-in-out capitalize tracking-wide"><%- data.name%></a>
            <% }) %>
        </div>
        <% }else{ %>
            <p>No Category found.</p>
        <% } %>
    </section>